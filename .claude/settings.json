      "Bash(gh * status:*)",
      "Bash(gh * verify:*)",
      "Bash(gh * view:*)",
      "Bash(gh * watch:*)",
      "Bash(gh api *issues/*/comments*)",
      "Bash(gh api *pulls/*/comments*)",
      "Bash(gh api *pulls/*/reviews*)",
      "Bash(gh browse:*)",
      "Bash(gh search:*)",
      "Bash(gh status:*)",
      "Bash(git add:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
