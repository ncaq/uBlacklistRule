      "Bash(nix eval:*)",
      "Bash(nix flake:*)",
      "Bash(nix fmt:*)",
      "Bash(nix search:*)",
      "Bash(nix-fast-build:*)",
      "Bash(nixfmt:*)",
      "Bash(prettier:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(statix:*)",
      "Bash(typos:*)",
      "Bash(zizmor:*)",
      "mcp__deepwiki",
      "mcp__github__get_commit",
      "mcp__github__get_file_contents",
      "mcp__github__get_label",
