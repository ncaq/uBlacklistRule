{
  "extraKnownMarketplaces": {
    "konoka": {
      "source": {
        "source": "github",
        "repo": "ncaq/konoka",
        "ref": "v6.2.0"
      }
    }
  },
  "enabledPlugins": {
    "kyosei@konoka": true,
    "nix-tasuke@konoka": true
  },
  "enableAllProjectMcpServers": true,
  "permissions": {
